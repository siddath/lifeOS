node_modules/
.vercel
*.log
.DS_Store

# Secrets — ship only the .example versions. Real keys never get committed.
.env
.env.*
!.env.example
.mcp.json

# Your instance config is SAFE TO COMMIT: dashboard/lifeos.config.json holds
# identity + toggles, never secrets — and committing it is how a static deploy
# (Vercel/GitHub Pages) actually renders as YOU instead of the demo persona.
# We only ignore the legacy repo-root copy (superseded by the dashboard/ one).
/lifeos.config.json

# Your private life data (the framework ships only templates + the demo persona)
02_Areas/**/*.md
!02_Areas/**/*.template.md
!02_Areas/README.md
reviews/*.md
!reviews/README.md

# Obsidian: keep shared config (app/core-plugins/community-plugins), ignore per-device state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/
.obsidian/themes/
.trash/
.env*
