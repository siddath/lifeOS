node_modules/
.vercel
*.log
.DS_Store

# Secrets — ship only the .example versions. Real keys never get committed.
.env
.env.*
!.env.example
.mcp.json

# Instance config: dashboard/lifeos.config.json holds identity + toggles, never
# secrets. Commit it in your PRIVATE instance (that's what makes a static deploy
# render as YOU) — in the public template / a public fork, leave it uncreated.
# We only ignore the legacy repo-root copy (superseded by the dashboard/ one).
/lifeos.config.json

# Your private life data (the framework ships only templates + the demo persona)
02_Areas/**/*.md
!02_Areas/**/*.template.md
!02_Areas/README.md
reviews/*.md
!reviews/README.md

# Obsidian: keep shared config (app/core-plugins/community-plugins), ignore per-device state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/
.obsidian/themes/
.trash/
