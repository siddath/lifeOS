{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "lifeos/task",
  "title": "Task",
  "type": "object",
  "required": ["title", "area", "priority", "status"],
  "properties": {
    "id": { "type": "string", "description": "Local id; generated client-side." },
    "notionId": { "type": ["string", "null"], "description": "Notion page id once synced." },
    "title": { "type": "string" },
    "area": { "type": "string", "description": "One of the area codes in lifeos.config.json." },
    "priority": { "type": "string", "enum": ["P1", "P2", "P3"] },
    "status": { "type": "string", "enum": ["open", "in-progress", "done"] },
    "due": { "type": "string", "description": "YYYY-MM-DD or empty." },
    "updatedAt": { "type": "string", "description": "ISO 8601 timestamp." }
  }
}
