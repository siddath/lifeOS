# LifeOS environment — copy to .env (gitignored) for local dev, and set the same
# keys as Vercel Environment Variables for the deployed sync functions.
# Secrets live ONLY here / in Vercel — never in lifeos.config.json.

# --- Notion 2-way sync (optional) -------------------------------------------
# Create an internal integration at https://www.notion.com/my-integrations,
# share your duplicated Tasks + Habits databases with it, then paste below.
NOTION_API_KEY=
NOTION_DATABASE_ID_TASKS=
NOTION_DATABASE_ID_HABITS=

# Shared secret that authenticates the dashboard -> serverless sync calls.
# Generate any long random string; set the identical value in the dashboard config.
SYNC_SHARED_SECRET=

# --- Planned connectors (not required for v1) -------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# BROKER_API_KEY=
